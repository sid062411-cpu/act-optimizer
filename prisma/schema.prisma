generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model TestResult {
  id             String   @id @default(cuid())
  date           DateTime
  englishRaw     Int
  englishScore   Int
  mathRaw        Int
  mathScore      Int
  readingRaw     Int
  readingScore   Int
  compositeScore Int
  source         String   @default("EXISTING")
  createdAt      DateTime @default(now())
}
